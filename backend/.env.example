# SEC60 Backend Environment Variables

# OpenAI API Key (optional - for enhanced AI explanations)
# OPENAI_API_KEY=sk-...

# Groq API Key (optional - alternative LLM provider)
# GROQ_API_KEY=gsk_...

# Tesseract OCR path (Windows example)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Demo mode - uses pre-seeded data without external APIs
DEMO_MODE=false

# Backend port
PORT=8000
